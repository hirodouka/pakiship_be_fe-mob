# Copy this file to `.env` and replace the placeholder values.
# Never commit `.env`.
#
# Client-safe values used by the PakiShip mobile app:
NODE_ENV=development
API_BASE_URL=http://YOUR_COMPUTER_LAN_IP:4000/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_PASSWORD_RESET_REDIRECT_URL=pakiship://reset-password

# Optional Expo-prefixed aliases are also supported:
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_COMPUTER_LAN_IP:4000/api
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# EXPO_PUBLIC_SUPABASE_PASSWORD_RESET_REDIRECT_URL=pakiship://reset-password
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Server-only secrets must stay in your backend/Vault/Secrets Manager:
# SUPABASE_SERVICE_ROLE_KEY=do-not-put-this-in-the-mobile-app
# ENABLE_SWAGGER=false
# PORT=4000
# ALLOWED_ORIGINS=http://localhost:5173
# API_CENTER_BASE_URL=https://apicenter.example.com
# API_CENTER_API_KEY=do-not-put-this-in-the-mobile-app
