{
  "name": "@implementsprint/sdk",
  "version": "1.1.2",
  "description": "Shared APICenter SDK for tribe-to-tribe calls, shared services, and governed gateway integrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "check:contracts": "node scripts/check-contract-compatibility.js",
    "test:gauth": "node scripts/test-gauth-flow.js",
    "smoke:payment-subscription:sdk": "node scripts/smoke-payment-subscription-sdk.js",
    "verify:private-sdk": "node scripts/verify-private-sdk.js",
    "verify:release": "node scripts/verify-release-tag.js",
    "pack:check": "npm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:shared:validate": "prisma validate",
    "db:shared:migration:new": "supabase migration new",
    "db:shared:migration:list": "supabase migration list",
    "db:shared:migration:push": "supabase db push",
    "db:shared:migration:push:dry": "supabase db push --dry-run",
    "db:shared:reset": "supabase db reset",
    "ci": "npm run verify:private-sdk && npm run check:contracts && npm run typecheck && npm run test && npm run build && npm run pack:check",
    "prepublishOnly": "npm run verify:private-sdk && npm run clean && npm run build"
  },
  "keywords": [
    "api-center",
    "sdk",
    "gateway",
    "tribe"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/node": "^25.7.0",
    "express": "^5.2.1",
    "prisma": "^7.8.0",
    "resend": "^6.12.3",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImplementSprint/api-shared.git"
  },
  "packageManager": "npm@11.6.2"
}
