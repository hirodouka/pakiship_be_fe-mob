{
  "serviceId": "payment",
  "serviceType": "shared",
  "name": "Payment Gateway",
  "baseUrl": "http://payment-service:4010",
  "requiredScopes": ["payment:charge", "payment:refund"],
  "exposes": [
    "/customers",
    "/customers/:id",
    "/products",
    "/products/:id",
    "/prices",
    "/prices/:id",
    "/checkout/sessions",
    "/checkout/sessions/:id",
    "/checkout/sessions/:id/status",
    "/checkout/sessions/by-reference/:referenceId/status",
    "/checkout/sessions/:id/cancelled",
    "/subscriptions",
    "/subscriptions/:id",
    "/subscriptions/by-reference/:referenceId",
    "/subscriptions/:id/cancel",
    "/subscriptions/:id/pause",
    "/subscriptions/:id/resume",
    "/subscriptions/:id/change-price",
    "/subscriptions/:id/invoices",
    "/invoices/:id",
    "/payments/:id/refunds",
    "/webhooks"
  ],
  "consumes": [],
  "healthCheck": "/health",
  "version": "1.0.0",
  "description": "Platform-owned payment gateway service (Stripe, etc.)",
  "ownerTeam": "platform-payments",
  "contact": "#platform-payments-oncall",
  "serviceTier": "critical",
  "costCenter": "CC-PAY-001"
}
