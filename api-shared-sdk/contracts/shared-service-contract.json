{
  "version": "2026-05-11",
  "sharedServices": [
    {
      "serviceId": "payment",
      "manifest": "shared-services/manifests/payment-manifest.json",
      "wrappers": [
        "paymentCreateCheckoutSession",
        "paymentGetCheckoutSession",
        "paymentGetCheckoutStatus",
        "paymentGetCheckoutStatusByReference",
        "paymentMarkCheckoutCancelled",
        "paymentCreateRefund",
        "paymentCreateCustomer",
        "paymentGetCustomer",
        "paymentCreateProduct",
        "paymentGetProduct",
        "paymentCreatePrice",
        "paymentGetPrice",
        "paymentCreateSubscription",
        "paymentGetSubscription",
        "paymentGetSubscriptionByReference",
        "paymentCancelSubscription",
        "paymentPauseSubscription",
        "paymentResumeSubscription",
        "paymentChangeSubscriptionPrice",
        "paymentListSubscriptionInvoices",
        "paymentGetInvoice"
      ],
      "endpoints": [
        "/customers",
        "/customers/:id",
        "/products",
        "/products/:id",
        "/prices",
        "/prices/:id",
        "/checkout/sessions",
        "/checkout/sessions/:id",
        "/checkout/sessions/:id/status",
        "/checkout/sessions/by-reference/:referenceId/status",
        "/checkout/sessions/:id/cancelled",
        "/subscriptions",
        "/subscriptions/:id",
        "/subscriptions/by-reference/:referenceId",
        "/subscriptions/:id/cancel",
        "/subscriptions/:id/pause",
        "/subscriptions/:id/resume",
        "/subscriptions/:id/change-price",
        "/subscriptions/:id/invoices",
        "/invoices/:id",
        "/payments/:id/refunds",
        "/webhooks"
      ]
    },
    {
      "serviceId": "email",
      "manifest": "shared-services/manifests/email-manifest.json",
      "wrappers": [
        "emailSend",
        "emailGetStatus"
      ],
      "endpoints": [
        "/send",
        "/templates",
        "/status"
      ]
    },
    {
      "serviceId": "sms",
      "manifest": "shared-services/manifests/sms-manifest.json",
      "wrappers": [
        "smsSend",
        "smsGetStatus"
      ],
      "endpoints": [
        "/send",
        "/status",
        "/templates"
      ]
    },
    {
      "serviceId": "gauth",
      "manifest": "shared-services/manifests/gauth-manifest.json",
      "wrappers": [
        "gauthGetAuthorizationUrl",
        "gauthExchangeCode",
        "gauthRefreshToken",
        "gauthLogout"
      ],
      "endpoints": [
        "/oauth/authorize",
        "/oauth/token",
        "/oauth/token/refresh",
        "/oauth/logout",
        "/health"
      ]
    },
    {
      "serviceId": "otp",
      "manifest": "shared-services/manifests/otp-manifest.json",
      "wrappers": [
        "otpGenerate",
        "otpVerify",
        "otpStatus"
      ],
      "endpoints": [
        "/generate",
        "/verify",
        "/status"
      ]
    },
    {
      "serviceId": "geo",
      "manifest": "shared-services/manifests/geo-manifest.json",
      "wrappers": [
        "geoGeocodeAddress",
        "geoReverseGeocode",
        "geoFenceCheck"
      ],
      "endpoints": [
        "/geocode",
        "/reverse-geocode",
        "/geofence/check"
      ]
    }
  ],
  "kafkaGovernance": {
    "requiredScopes": [
      "external:kafka:read",
      "external:kafka:write"
    ],
    "wrappers": [
      "kafkaGetGovernanceCatalog",
      "kafkaPublish"
    ]
  }
}
